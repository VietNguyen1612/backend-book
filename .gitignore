# .gitignore
#
# Only personal/local and generated artifacts are ignored below. The project
# deliverables are intentionally TRACKED and must NOT be added here:
#   README.md, AUDIT.md, _config.yml, search.md,
#   .markdownlint-cli2.yaml, ruff.toml, scripts/, assets/, .github/, chapters/

# --- Self-study workflow: local only, never commit ---
# Personal Obsidian study vault and notes
self-notes/
# Obsidian app config + plugins (per-machine study tooling)
.obsidian/
.trash/

# --- Jekyll build output ---
_site/
.jekyll-cache/
.jekyll-metadata

# --- Node / npm (markdownlint-cli2 is run via npx) ---
node_modules/

# --- Python tooling artifacts (homework skeletons, linters) ---
__pycache__/
*.py[cod]
.ruff_cache/
.pytest_cache/
.mypy_cache/

# --- Editors / IDEs ---
.vscode/
.idea/
*.swp

# --- OS / editor noise ---
.DS_Store
Thumbs.db
